{
  "name": "@kmos/language",
  "version": "1.0.0-pc.2",
  "private": true,
  "type": "module",
  "description": "KMOS Language domain service (KMOS-0002/0004 Language, KMOS-0005 institutional memory): composes transcript-correction, knowledge-extraction and translation capabilities via the Workflow + Runtime. Holds no business logic of its own.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@kmos/canonical-kernel": "*",
    "@kmos/knowledge": "*",
    "@kmos/capability-registry": "*",
    "@kmos/capability-runtime": "*",
    "@kmos/workflow": "*",
    "@kmos/reference-capabilities": "*"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "node --experimental-strip-types --import ../../tools/dev/register.mjs --test test/*.test.ts"
  }
}
