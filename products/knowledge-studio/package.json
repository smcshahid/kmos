{
  "name": "@kmos/knowledge-studio-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Knowledge Studio — the flagship KMOS ecosystem application. Drop long-form knowledge in, leave with understanding: a thin product layer over KMOS that turns media into verifiable, navigable knowledge (transcript, chapters, concepts, evidence, lineage, trust, search, collections, downloads).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@kmos/canonical-kernel": "*",
    "@kmos/identity": "*",
    "@kmos/assets": "*",
    "@kmos/knowledge": "*",
    "@kmos/governance": "*",
    "@kmos/events": "*",
    "@kmos/capability-registry": "*",
    "@kmos/capability-runtime": "*",
    "@kmos/search": "*",
    "@kmos/platform-catalog": "*",
    "@kmos/media": "*",
    "@kmos/language": "*"
  },
  "scripts": {
    "build": "tsc --build",
    "start": "node --experimental-strip-types --import ../../tools/dev/register.mjs src/index.ts",
    "test": "node --experimental-strip-types --import ../../tools/dev/register.mjs --test test/*.test.ts"
  }
}
